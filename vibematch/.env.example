# Скопируй этот файл в .env и вставь свои ключи.

# Anthropic API — читается ТОЛЬКО прокси-сервером (server/proxy.mjs), не попадает в браузер.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxx

# Порт прокси-сервера (по умолчанию 8787)
PROXY_PORT=8787

# Supabase (публичные ключи — безопасно хранить в клиентском коде)
VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Sentry (опционально — краш-репорты)
VITE_SENTRY_DSN=https://xxxx@oxxxx.ingest.sentry.io/xxxx
